function LifecycleController.onCharacterReady(newChar)
    if not State.alive then
        return
    end

    if not refreshCharacterRefs(newChar, true) then
        return
    end

    CharacterController.enableNoClip()

    task.delay(0.35, function()
        if not State.alive then
            return
        end

        refreshCharacterRefs(LocalPlayer.Character, true)
        CharacterController.enableNoClip()

        if Config.FPSBoost then
            VisualController.apply(true)
        else
            MovementController.syncHoldState()
        end

        if Config.AutoEquip then
            EquipController.equipSelected(true)
        end
    end)
end

function LifecycleController.start()
    refreshCharacterRefs(LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait(), true)
    CharacterController.enableNoClip()

    if State.connections.CharacterAdded then
        State.connections.CharacterAdded:Disconnect()
    end

    State.connections.CharacterAdded = LocalPlayer.CharacterAdded:Connect(function(newChar)
        LifecycleController.onCharacterReady(newChar)
    end)
end

function LifecycleController.startFarmLoop()
    task.spawn(function()
        while State.alive do
            local waitTime = FarmController.step()
            task.wait(waitTime or INTERNAL.IDLE_TICK)
        end
    end)
end

function LifecycleController.startStatusLoop()
    task.spawn(function()
        while State.alive do
            NPCController.refreshCache(false)

            local statusParagraph = State.ui.StatusParagraph
            if statusParagraph then
                local npcCount = #State.npcCache.models
                local timedCount = #State.npcCache.timed
                local selectedMobCount = countEnabled(Config.SelectedEnemies)
                local selectedBossCount = countEnabled(Config.SelectedBosses)

                local statusText = string.format(
                    "Mode: %s\nTarget: %s\nTarget Type: %s\nEquip Slot: %s\nLast Equipped: %s\nAutoEquip: %s\nFPS Boost: %s\nNo Collision: %s\nAir Hold: %s\nNPCs loaded: %d\nTimed Bosses alive: %d\nSelected Mobs: %d\nSelected Bosses: %d\nTheme: %s",
                    tostring(State.LastMode),
                    tostring(State.LastTarget),
                    tostring(State.activeTargetKind),
                    tostring(Config.EquipLabel),
                    tostring(State.LastEquipped),
                    Config.AutoEquip and "ON" or "OFF",
                    State.fpsBoostEnabled and "ON" or "OFF",
                    State.connections.NoClip and "ON" or "OFF",
                    State.holdEnabled and "ON" or "OFF",
                    npcCount,
                    timedCount,
                    selectedMobCount,
                    selectedBossCount,
                    tostring(WindUI:GetCurrentTheme())
                )

                statusParagraph:SetDesc(statusText)
            end

            task.wait(INTERNAL.STATUS_REFRESH)
        end
    end)
end

