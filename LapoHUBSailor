local function getCharacter()
    State.Character = LocalPlayer.Character
    State.Humanoid = State.Character and State.Character:FindFirstChildOfClass("Humanoid") or nil
    State.Root = State.Character and State.Character:FindFirstChild("HumanoidRootPart") or nil
end

local function getHumanoid(model)
    return model and model:FindFirstChildOfClass("Humanoid") or nil
end

local function getModelRoot(model)
    return model and (
        model:FindFirstChild("HumanoidRootPart")
        or model.PrimaryPart
        or model:FindFirstChildWhichIsA("BasePart")
    ) or nil
end

local function cleanName(name)
    local s = tostring(name or "")
    s = s:gsub("%d+$", "")
    s = s:gsub("%s+$", "")
    return s ~= "" and s or tostring(name)
end

local function normalizeName(name)
    local s = tostring(name or ""):lower()
    s = s:gsub("%d+$", "")
    s = s:gsub("[%[%]%(%)%{%}]", "")
    s = s:gsub("[_%-%s]+", "")
    return s
end

local function deriveSpawnKey(name)
    local s = normalizeName(name)
    s = s:gsub("spawnpoint", "")
    s = s:gsub("spawner", "")
    s = s:gsub("spawn", "")
    s = s:gsub("npc", "")
    s = s:gsub("mob", "")
    s = s:gsub("boss", "")
    return s
end

local function hasKeyword(text, keywords)
    text = string.lower(tostring(text or ""))

    for _, word in ipairs(keywords) do
        if text:find(word, 1, true) then
            return true
        end
    end

    return false
end

local function getPivotCFrame(obj)
    if not obj then
        return nil
    end

    if obj:IsA("BasePart") then
        return obj.CFrame
    end

    if obj:IsA("Model") then
        local root = getModelRoot(obj)
        if root then
            return root.CFrame
        end

        local ok, cf = pcall(function()
            return obj:GetPivot()
        end)

        if ok then
            return cf
        end
    end

    return nil
end

local function getNPCFolder()
    if Config.NPCFolderName then
        local folder = Workspace:FindFirstChild(Config.NPCFolderName)
        if folder then
            return folder
        end
    end

    for _, name in ipairs({ "NPCs", "Enemies", "Mobs" }) do
        local folder = Workspace:FindFirstChild(name)
        if folder then
            return folder
        end
    end

    return nil
end

local function isAliveHumanoidModel(model)
    if not model or not model:IsA("Model") or not model.Parent then
        return false
    end

    if State.Character and model == State.Character then
        return false
    end

    if Players:GetPlayerFromCharacter(model) then
        return false
    end

    if tostring(model.Name):find("TrainingDummy") then
        return false
    end

    local hum = getHumanoid(model)
    local root = getModelRoot(model)

    if not hum or hum.Health <= 0 or not root then
        return false
    end

    return true
end

local function isServiceNPC(model)
    if not isAliveHumanoidModel(model) then
        return false
    end

    local hum = getHumanoid(model)
    local root = getModelRoot(model)

    if hasKeyword(model.Name, IgnoreKeywords) then
        return true
    end

    if hum and hasKeyword(hum.DisplayName, IgnoreKeywords) then
        return true
    end

    local hasInteraction = false

    for _, d in ipairs(model:GetDescendants()) do
        if d:IsA("ProximityPrompt") or d:IsA("ClickDetector") or d:IsA("Dialog") then
            hasInteraction = true
        end

        if hasKeyword(d.Name, IgnoreKeywords) then
            return true
        end

        if d:IsA("TextLabel") or d:IsA("TextButton") then
            if hasKeyword(d.Text, IgnoreKeywords) then
                return true
            end
        end
    end

    if hasInteraction and root and root.Anchored then
        return true
    end

    return false
end

local function isCombatNPC(model)
    return isAliveHumanoidModel(model) and not isServiceNPC(model)
end

local function isTimedBoss(model)
    return model and TIMED_BOSS_LOOKUP[model.Name] == true or false
end

local function isBoss(model)
    if not isCombatNPC(model) then
        return false
    end

    local hum = getHumanoid(model)

    if model:GetAttribute("Boss") == true or model:GetAttribute("IsBoss") == true then
        return true
    end

    if isTimedBoss(model) then
        return true
    end

    if hasKeyword(model.Name, BossKeywords) then
        return true
    end

    if hum and hasKeyword(hum.DisplayName, BossKeywords) then
        return true
    end

    return false
end

local function scanCombatNPCs()
    local list = {}
    local seen = {}
    local folder = getNPCFolder()

    local function addModel(inst)
        if inst:IsA("Model") and isCombatNPC(inst) and not seen[inst] then
            local parentModel = inst.Parent
            if parentModel and parentModel:IsA("Model") and getHumanoid(parentModel) then
                return
            end

            seen[inst] = true
            table.insert(list, inst)
        end
    end

    if folder then
        for _, inst in ipairs(folder:GetDescendants()) do
            addModel(inst)
        end
    else
        for _, inst in ipairs(Workspace:GetDescendants()) do
            addModel(inst)
        end
    end

    return list
end

local function isAllowedTarget(model)
    if not isCombatNPC(model) then
        return false
    end

    local boss = isBoss(model)
    local timed = isTimedBoss(model)

    if Config.FarmTimedBosses and not timed then
        return false
    end

    if Config.FarmAllMobsTimedBosses then
        if boss and not timed then
            return false
        end
    else
        if boss and not Config.FarmBosses and not Config.FarmTimedBosses then
            return false
        end

        if not boss and not Config.FarmMobs then
            return false
        end
    end

    if Config.SelectedTarget ~= "Any" then
        local base = cleanName(model.Name)
        if base ~= Config.SelectedTarget and model.Name ~= Config.SelectedTarget then
            return false
        end
    end

    return true
end

local function findModelCFrameByName(baseName)
    local wanted = normalizeName(baseName)
    local bestCF, bestDist = nil, math.huge

    if not State.Root then
        return nil
    end

    for _, inst in ipairs(Workspace:GetDescendants()) do
        if inst:IsA("Model") and inst ~= State.Character and not Players:GetPlayerFromCharacter(inst) then
            if normalizeName(cleanName(inst.Name)) == wanted or normalizeName(inst.Name) == wanted then
                local cf = getPivotCFrame(inst)
                if cf then
                    local dist = (State.Root.Position - cf.Position).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        bestCF = cf
                    end
                end
            end
        end
    end

    return bestCF
end

local function findSpawnCFrameByName(baseName)
    local wanted = deriveSpawnKey(baseName)
    local bestCF, bestDist = nil, math.huge

    if wanted == "" or not State.Root then
        return nil
    end

    for _, inst in ipairs(Workspace:GetDescendants()) do
        local lower = tostring(inst.Name):lower()
        if lower:find("spawn", 1, true) or lower:find("spawner", 1, true) then
            local key = deriveSpawnKey(inst.Name)
            if key ~= "" and key == wanted then
                local cf = getPivotCFrame(inst)
                if cf then
                    local dist = (State.Root.Position - cf.Position).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        bestCF = cf
                    end
                end
            end
        end
    end

    return bestCF
end

local function getInfiniteRangeCFrame(name)
    return findModelCFrameByName(name) or findSpawnCFrameByName(name)
end

local function acquireTarget()
    if not State.Root then
        return nil
    end

    local timedBest, timedDist = nil, math.huge
    local best, bestDist = nil, math.huge

    for _, npc in ipairs(scanCombatNPCs()) do
        if isAllowedTarget(npc) then
            local root = getModelRoot(npc)
            if root then
                local dist = (State.Root.Position - root.Position).Magnitude

                if isTimedBoss(npc) then
                    if dist < timedDist then
                        timedDist = dist
                        timedBest = npc
                    end
                else
                    if dist < bestDist then
                        bestDist = dist
                        best = npc
                    end
                end
            end
        end
    end

    return timedBest or best
end

local function resolveTarget()
    if isAllowedTarget(State.Target) then
        return State.Target
    end

    State.Target = acquireTarget()
    State.TargetName = State.Target and State.Target.Name or "None"
    return State.Target
end

local function getTargetCFrame(npc)
    local root = npc and getModelRoot(npc)
    if not root then
        return nil
    end

    local pos = root.Position - (root.CFrame.LookVector * Config.TeleportDistance) + Vector3.new(0, Config.TeleportHeight, 0)
    return CFrame.new(pos, root.Position)
end

local function teleportToCFrame(cf)
    if State.Root and cf then
        State.Root.CFrame = cf
    end
end

local function teleportToTarget(npc)
    local cf = getTargetCFrame(npc)
    if cf then
        teleportToCFrame(cf)
    end
end

local function tryInfiniteRangeTeleport()
    if not Config.InfiniteRangeTP or not State.Root then
        return false
    end

    local candidates = {}

    if Config.FarmTimedBosses then
        for _, name in ipairs(TIMED_BOSS_NAMES) do
            if Config.SelectedTarget == "Any" or Config.SelectedTarget == name or Config.SelectedTarget == cleanName(name) then
                table.insert(candidates, name)
            end
        end
    elseif Config.FarmAllMobsTimedBosses then
        if Config.SelectedTarget ~= "Any" then
            table.insert(candidates, Config.SelectedTarget)
        end

        for _, name in ipairs(TIMED_BOSS_NAMES) do
            table.insert(candidates, name)
        end
    else
        if Config.SelectedTarget ~= "Any" then
            table.insert(candidates, Config.SelectedTarget)
        end
    end

    local bestCF, bestDist = nil, math.huge

    for _, name in ipairs(candidates) do
        local cf = getInfiniteRangeCFrame(name)
        if cf then
            local dist = (State.Root.Position - cf.Position).Magnitude
            if dist < bestDist then
                bestDist = dist
                bestCF = cf
            end
        end
    end

    if bestCF then
        teleportToCFrame(bestCF)
        return true
    end

    return false
end

local function getEquippedTool()
    return State.Character and State.Character:FindFirstChildOfClass("Tool") or nil
end

local function tapEquipSlot()
    if not Config.AutoEquip then
        return
    end

    local now = tick()
    if now - State.LastEquip < Config.EquipCooldown then
        return
    end

    local key = SlotMap[Config.EquipSlot]
    if not key then
        return
    end

    State.LastEquip = now
    VirtualInputManager:SendKeyEvent(true, key, false, game)
    task.wait()
    VirtualInputManager:SendKeyEvent(false, key, false, game)
end

local function attack()
    if not Config.AutoAttack then
        return
    end

    local tool = getEquippedTool()
    if tool then
        pcall(function()
            tool:Activate()
        end)
    end
end

local function disableAirHold(oldChar)
    local char = oldChar or State.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")

    if root then
        local bp = root:FindFirstChild(Config.AirHoldPosName)
        local bg = root:FindFirstChild(Config.AirHoldGyroName)

        if bp then
            bp:Destroy()
        end

        if bg then
            bg:Destroy()
        end
    end

    if State.Humanoid then
        State.Humanoid.AutoRotate = true
    end
end

local function holdInAir(cf)
    if not Config.AirHold or not State.Root then
        disableAirHold()
        return
    end

    local bp = State.Root:FindFirstChild(Config.AirHoldPosName)
    local bg = State.Root:FindFirstChild(Config.AirHoldGyroName)

    if not bp then
        bp = Instance.new("BodyPosition")
        bp.Name = Config.AirHoldPosName
        bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bp.P = 100000
        bp.D = 1250
        bp.Parent = State.Root
    end

    if not bg then
        bg = Instance.new("BodyGyro")
        bg.Name = Config.AirHoldGyroName
        bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bg.P = 100000
        bg.D = 1250
        bg.Parent = State.Root
    end

    bp.Position = cf.Position
    bg.CFrame = cf

    State.Root.AssemblyLinearVelocity = Vector3.zero
    State.Root.AssemblyAngularVelocity = Vector3.zero

    if State.Humanoid then
        State.Humanoid.AutoRotate = false
        State.Humanoid.Sit = false
    end
end

local function remember(inst, prop)
    State.Hidden[inst] = State.Hidden[inst] or {}
    if State.Hidden[inst][prop] == nil then
        State.Hidden[inst][prop] = inst[prop]
    end
end

local function isProtectedWorkspaceRoot(root)
    if not root or not root.Parent then
        return true
    end

    if root == Workspace.CurrentCamera then
        return true
    end

    if root:IsA("Terrain") then
        return true
    end

    if State.Character and (root == State.Character or root:IsDescendantOf(State.Character)) then
        return true
    end

    if Players:GetPlayerFromCharacter(root) then
        return true
    end

    if root:IsA("Model") and getHumanoid(root) then
        return true
    end

    return false
end

local function hideRoot(root)
    if isProtectedWorkspaceRoot(root) then
        return
    end

    for _, inst in ipairs(root:GetDescendants()) do
        if inst:IsA("BasePart") then
            remember(inst, "LocalTransparencyModifier")
            inst.LocalTransparencyModifier = 1
        elseif inst:IsA("Decal") or inst:IsA("Texture") then
            remember(inst, "Transparency")
            inst.Transparency = 1
        elseif inst:IsA("ParticleEmitter") or inst:IsA("Trail") or inst:IsA("Beam") then
            remember(inst, "Enabled")
            inst.Enabled = false
        end
    end

    if root:IsA("BasePart") then
        remember(root, "LocalTransparencyModifier")
        root.LocalTransparencyModifier = 1
    end
end

local function restoreFPSBoost()
    for inst, props in pairs(State.Hidden) do
        if inst and inst.Parent then
            for prop, value in pairs(props) do
                pcall(function()
                    inst[prop] = value
                end)
            end
        end
    end

    table.clear(State.Hidden)
end

local function applyFPSBoost()
    restoreFPSBoost()

    if not Config.FPSBoost then
        return
    end

    for _, root in ipairs(Workspace:GetChildren()) do
        hideRoot(root)
    end
end

local function getTargetOptions()
    local seen = { ["Any"] = true }
    local values = { "Any" }

    for _, npc in ipairs(scanCombatNPCs()) do
        local base = cleanName(npc.Name)
        if not seen[base] then
            seen[base] = true
            table.insert(values, base)
        end
    end

    table.sort(values, function(a, b)
        if a == "Any" then
            return true
        end
        if b == "Any" then
            return false
        end
        return a < b
    end)

    return values
end

local function refreshTargetDropdown()
    if State.TargetDropdown then
        State.TargetDropdown:Refresh(getTargetOptions())
    end
end

local function resetCharacter(newChar)
    disableAirHold(State.Character)

    State.Character = newChar or LocalPlayer.Character
    State.Humanoid = nil
    State.Root = nil
    State.Target = nil
    State.TargetName = "None"
    State.LastEquip = 0

    if State.Character then
        State.Humanoid = State.Character:WaitForChild("Humanoid", 10)
        State.Root = State.Character:WaitForChild("HumanoidRootPart", 10)
    end

    if Config.FPSBoost then
        applyFPSBoost()
    end

    refreshTargetDropdown()
end

