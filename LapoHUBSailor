State.Connections.CharacterAdded = LocalPlayer.CharacterAdded:Connect(function(char)
    resetCharacter(char)
end)

State.Connections.CharacterRemoving = LocalPlayer.CharacterRemoving:Connect(function(char)
    disableAirHold(char)
    State.Target = nil
    State.TargetName = "None"
end)

State.Connections.WorkspaceAdded = Workspace.ChildAdded:Connect(function(child)
    if Config.FPSBoost then
        task.defer(function()
            if Config.FPSBoost and child and child.Parent == Workspace then
                hideRoot(child)
            end
        end)
    end
end)

State.Connections.NoClip = RunService.Stepped:Connect(function()
    if not Config.NoClip or not State.Character then
        return
    end

    for _, inst in ipairs(State.Character:GetDescendants()) do
        if inst:IsA("BasePart") then
            inst.CanCollide = false
        end
    end
end)

task.spawn(function()
    while true do
        refreshTargetDropdown()
        task.wait(2)
    end
end)

task.spawn(function()
    while true do
        if not State.Character or not State.Character.Parent or not State.Humanoid or not State.Root or State.Humanoid.Health <= 0 then
            resetCharacter(LocalPlayer.Character)
            task.wait(0.25)
        else
            local farming = Config.FarmMobs or Config.FarmBosses
            local target = farming and resolveTarget() or nil

            if target then
                if Config.AutoEquip then
                    tapEquipSlot()
                end

                teleportToTarget(target)
                attack()

                if Config.AirHold and State.Root then
                    holdInAir(State.Root.CFrame)
                end
            else
                State.Target = nil
                State.TargetName = "None"

                if Config.AirHold and State.Root then
                    holdInAir(State.Root.CFrame)
                else
                    disableAirHold()
                end
            end

            task.wait(Config.Delay)
        end
    end
end)