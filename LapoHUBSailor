        Content = content,
        Icon = icon,
        Duration = duration or 3,
    })
end

local function applyNoCollisionToPart(part)
    if not part or not part:IsA("BasePart") then
        return
    end

    part.CanCollide = false
    part.CanTouch = false
    part.CanQuery = false
end

function CharacterController.rebuildPartCache()
    table.clear(State.character.partCache)

    if not char then
        return
    end

    for _, inst in ipairs(char:GetDescendants()) do
        if inst:IsA("BasePart") then
            State.character.partCache[inst] = true
            applyNoCollisionToPart(inst)
        end
    end
end

function CharacterController.enableNoClip()
    if not refreshCharacterRefs() or not char then
        return
    end

    CharacterController.rebuildPartCache()

    if State.connections.NoClipDesc then
        State.connections.NoClipDesc:Disconnect()
        State.connections.NoClipDesc = nil
    end

    State.connections.NoClipDesc = char.DescendantAdded:Connect(function(inst)
        if not inst:IsA("BasePart") then
            return
        end

        State.character.partCache[inst] = true

        task.defer(function()
            if State.alive and char and inst.Parent and inst:IsDescendantOf(char) then
                applyNoCollisionToPart(inst)
            end
        end)
    end)

    if not State.connections.NoClip then
        State.connections.NoClip = RunService.Stepped:Connect(function()
            if not char or not char.Parent then
                return
            end

            for part in pairs(State.character.partCache) do
                if not part or not part.Parent or not part:IsDescendantOf(char) then
                    State.character.partCache[part] = nil
                elseif part.CanCollide or part.CanTouch or part.CanQuery then
                    applyNoCollisionToPart(part)
                end
            end
        end)
    end
end

function CharacterController.stopNoClip()
    if State.connections.NoClip then
        State.connections.NoClip:Disconnect()
        State.connections.NoClip = nil
    end

    if State.connections.NoClipDesc then
        State.connections.NoClipDesc:Disconnect()
        State.connections.NoClipDesc = nil
    end
end

function NPCController.getBaseName(name)
    return (tostring(name or ""):gsub("%d+$", ""))
end

function NPCController.isBossName(name)
    return tostring(name or ""):match("Boss$") ~= nil or TIMED_BOSS_LOOKUP[tostring(name or "")] == true
end

function NPCController.getHumanoid(model)
    if not model then
        return nil
    end

    return model:FindFirstChildOfClass("Humanoid")
end

function NPCController.getRoot(model)
    if not model then
        return nil
    end

    return model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChild("RootPart")
        or model.PrimaryPart
        or model:FindFirstChildWhichIsA("BasePart")
end

function NPCController.isTrainingDummy(model)
    if not model then
        return false
    end

    return model.Name:lower():find("trainingdummy", 1, true) ~= nil
end

function NPCController.isAlive(model)
    if not model or not model.Parent then
        return false
    end

    local npcHum = NPCController.getHumanoid(model)
    if npcHum then
        return npcHum.Health > 0
    end

    return true
end

function NPCController.isValid(model)
    if not model or not model.Parent or not model:IsA("Model") then
        return false
    end

    if NPCController.isTrainingDummy(model) then
        return false
    end

    if not NPCController.isAlive(model) then
        return false
    end

    if NPCController.getRoot(model) then
        return true
    end

    return pcall(function()
        return model:GetPivot()
    end)
end

function NPCController.isCandidateModel(model)
    if not model or not model.Parent or not model:IsA("Model") then
        return false
    end

    if NPCController.isTrainingDummy(model) then
        return false
    end

    return NPCController.getHumanoid(model) ~= nil
        or NPCController.getRoot(model) ~= nil
        or model.PrimaryPart ~= nil
end

function NPCController.collectModels(folder)
    local result = {}
    if not folder then
        return result
    end

    for _, obj in ipairs(folder:GetChildren()) do
        if NPCController.isCandidateModel(obj) then
            table.insert(result, obj)
        end
    end

    if #result > 0 then
        return result
    end

    local seen = {}

    for _, obj in ipairs(folder:GetDescendants()) do
        if NPCController.isCandidateModel(obj) and not seen[obj] then
            seen[obj] = true
            table.insert(result, obj)
        end
    end

    return result
end

function NPCController.collectFallbackWorkspaceModels()
    local result = {}
    local seen = {}
    local npcFolder = getNPCFolder()

    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model")
            and not seen[obj]
            and not NPCController.isTrainingDummy(obj)
            and (not char or not obj:IsDescendantOf(char))
            and not Players:GetPlayerFromCharacter(obj)
            and (npcFolder == nil or obj:IsDescendantOf(npcFolder) or obj.Name:match("Boss$") or obj:FindFirstChildOfClass("Humanoid"))
        then
            if NPCController.isCandidateModel(obj) then
                seen[obj] = true
                table.insert(result, obj)
            end
        end
    end

    return result
end

function NPCController.getSearchModels()
    local folder = getNPCFolder()
    local models = NPCController.collectModels(folder)

    if #models > 0 then
        return models
    end

    return NPCController.collectFallbackWorkspaceModels()
end

function NPCController.refreshCache(force)
    local now = os.clock()

    if not force and (now - State.npcCache.indexedAt) < INTERNAL.NPC_CACHE_TTL then
        return State.npcCache
    end

    local validNPCs = {}
    local timedBosses = {}
    
    for _, obj in ipairs(NPCController.getSearchModels()) do
        if NPCController.isValid(obj) then
            table.insert(validNPCs, obj)

            if TIMED_BOSS_LOOKUP[obj.Name] then
                table.insert(timedBosses, obj)
            end
        end
    end

    State.npcCache.models = validNPCs
    State.npcCache.timed = timedBosses
    State.npcCache.indexedAt = now

    return State.npcCache
end

function NPCController.getValidNPCs(force)
    return NPCController.refreshCache(force).models
end

function NPCController.getTimedBosses(force)
    return NPCController.refreshCache(force).timed
end

function NPCController.getListableNPCs()
    local list = {}
    local seen = {}

    for _, obj in ipairs(NPCController.getSearchModels()) do
        if not NPCController.isTrainingDummy(obj) and not seen[obj] then
            seen[obj] = true
            table.insert(list, obj)
        end
    end

    return list
end

function NPCController.getGroupedList(wantBosses, force)
    local seen = {}
    local grouped = {}

    NPCController.refreshCache(force)

    for _, npc in ipairs(NPCController.getListableNPCs()) do
        local isBoss = NPCController.isBossName(npc.Name)

        if wantBosses == isBoss then
            local baseName = NPCController.getBaseName(npc.Name)

            if baseName ~= "" and not seen[baseName] then
                seen[baseName] = true
                table.insert(grouped, baseName)
            end
        end
    end

    table.sort(grouped)
    return grouped
end

function NPCController.getDistanceFromCharacter(model)
    if not refreshCharacterRefs() or not hrp then
        return math.huge
    end

    local root = NPCController.getRoot(model)
    if not root then
        return math.huge
    end

    return (hrp.Position - root.Position).Magnitude
end

function NPCController.findNearestValidAny()
    local best = nil
    local bestDist = math.huge

    for _, npc in ipairs(NPCController.getValidNPCs(true)) do
        local d = NPCController.getDistanceFromCharacter(npc)
        if d < bestDist then
            bestDist = d
            best = npc
        end
    end

    if best then
        return best, bestDist
    end

    for _, npc in ipairs(NPCController.getListableNPCs()) do
        if NPCController.isValid(npc) then
            local d = NPCController.getDistanceFromCharacter(npc)
            if d < bestDist then
                bestDist = d
                best = npc
            end
        end
    end

    return best, bestDist
end

function EquipController.getEquippedTool()
    if not refreshCharacterRefs() or not char then
        return nil
    end

    for _, obj in ipairs(char:GetChildren()) do
        if obj:IsA("Tool") then
            return obj
        end
    end

    return nil
end

function EquipController.weaponMatches(tool, weaponType)
    if not tool or not tool:IsA("Tool") then
        return false
    end

    local toolName = tool.Name:lower()
    local targetType = tostring(weaponType or ""):lower()

    if toolName == targetType then
        return true
    end

    if targetType == "melee" then
        return toolName:find("melee", 1, true) ~= nil
            or toolName:find("combat", 1, true) ~= nil
            or toolName:find("fist", 1, true) ~= nil
            or toolName:find("style", 1, true) ~= nil
    end

    if targetType == "sword" then
        return toolName:find("sword", 1, true) ~= nil
            or toolName:find("blade", 1, true) ~= nil
            or toolName:find("katana", 1, true) ~= nil
    end

    if targetType == "fruit" then
        return toolName:find("fruit", 1, true) ~= nil
            or toolName:find("devil", 1, true) ~= nil
    end

    return false
end

function EquipController.findWeaponTool(weaponType)
    if not refreshCharacterRefs() then
        return nil
    end

    local backpack = LocalPlayer:FindFirstChild("Backpack")

    for _, container in ipairs({ char, backpack }) do
        if container then
            for _, obj in ipairs(container:GetChildren()) do
                if EquipController.weaponMatches(obj, weaponType) then
                    return obj
                end
            end
        end
    end

    return nil
end

function EquipController.tapSlot(slot)
    local info = SLOT_INFO[slot]
    if not info then
        return false
    end

    if VirtualInputManager then
        local ok = pcall(function()
            VirtualInputManager:SendKeyEvent(true, info.KeyCode, false, game)
            task.wait()
            VirtualInputManager:SendKeyEvent(false, info.KeyCode, false, game)
        end)

        if ok then
            return true
        end
    end

    local virtualKeyBySlot = {
        [1] = 0x31,
        [2] = 0x32,
        [3] = 0x33,
    }

    if typeof(keypress) == "function" and typeof(keyrelease) == "function" and virtualKeyBySlot[slot] then
        local ok = pcall(function()
            keypress(virtualKeyBySlot[slot])
            task.wait()
            keyrelease(virtualKeyBySlot[slot])
        end)

        if ok then
            return true
        end
    end

    return false
end

function EquipController.setSelection(value)
    if typeof(value) == "table" then
        value = value[1]
    end

    local slot = LABEL_TO_SLOT[value]
    if not slot then
        slot = tonumber(tostring(value):match("^(%d+)")) or 1
    end

    slot = math.clamp(slot, 1, 3)
    Config.EquipSlot = slot
    Config.EquipLabel = SLOT_INFO[slot].Label
    State.lastEquipSlot = nil
end

function EquipController.equipSelected(force)
    if not force and not Config.AutoEquip then
        return false
    end

    if not refreshCharacterRefs() or not hum then
        return false
    end

    local now = os.clock()
    local slotInfo = SLOT_INFO[Config.EquipSlot] or SLOT_INFO[1]
    local currentTool = EquipController.getEquippedTool()

    if currentTool and EquipController.weaponMatches(currentTool, slotInfo.TypeName) then
        State.LastEquipped = currentTool.Name
        State.lastEquipSlot = Config.EquipSlot
        return true
    end

    if not force and (now - State.lastEquipAt) < INTERNAL.EQUIP_COOLDOWN then
        return false
    end

    State.lastEquipAt = now

    if currentTool then
        pcall(function()
            hum:UnequipTools()
        end)
    end

    if EquipController.tapSlot(Config.EquipSlot) then
        task.wait(0.04)

        local tappedTool = EquipController.getEquippedTool()
        if tappedTool and EquipController.weaponMatches(tappedTool, slotInfo.TypeName) then
            State.LastEquipped = tappedTool.Name
            State.lastEquipSlot = Config.EquipSlot
            return true
        end
    end

    local fallbackTool = EquipController.findWeaponTool(slotInfo.TypeName)
    if fallbackTool then
        pcall(function()
            hum:EquipTool(fallbackTool)
        end)

        task.wait(0.03)

        local equippedTool = EquipController.getEquippedTool()
        if equippedTool and EquipController.weaponMatches(equippedTool, slotInfo.TypeName) then
            State.LastEquipped = equippedTool.Name
            State.lastEquipSlot = Config.EquipSlot
            return true
        end
    end

    State.LastEquipped = slotInfo.Label .. " (failed)"
    return false
end

function CombatController.getAttackCooldown()
    local cd = tonumber(Config.AttackDelay) or 0.12
    return math.clamp(cd, 0.03, 0.6)
end

function CombatController.tryActivateTool()
    if not Config.AutoAttack then
        return false
    end

    if not refreshCharacterRefs() or not char or not hum or hum.Health <= 0 then
        return false
    end

    local now = os.clock()
    if (now - (State.lastAttackAt or 0)) < CombatController.getAttackCooldown() then
        return false
    end

    local tool = EquipController.getEquippedTool()
    if not tool and Config.AutoEquip then
        EquipController.equipSelected(false)
        tool = EquipController.getEquippedTool()
    end

    if not tool then
        return false
    end

    State.lastAttackAt = now
    return pcall(function()
        tool:Activate()
    end)
end

function MovementController.zeroVelocity()
    if not hrp then
        return
    end

    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero
end

function MovementController.ensureHoldInstances()
    if not refreshCharacterRefs() or not hrp then
        return nil, nil
    end

    local bodyPosition = hrp:FindFirstChild(HOLD_POSITION_NAME)
    local bodyGyro = hrp:FindFirstChild(HOLD_GYRO_NAME)

    if not bodyPosition then
        bodyPosition = Instance.new("BodyPosition")
        bodyPosition.Name = HOLD_POSITION_NAME
        bodyPosition.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bodyPosition.P = INTERNAL.HOLD_POSITION_P
        bodyPosition.D = INTERNAL.HOLD_POSITION_D
        bodyPosition.Parent = hrp
    end

    if not bodyGyro then
        bodyGyro = Instance.new("BodyGyro")
        bodyGyro.Name = HOLD_GYRO_NAME
        bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bodyGyro.P = INTERNAL.HOLD_GYRO_P
        bodyGyro.D = INTERNAL.HOLD_GYRO_D
        bodyGyro.Parent = hrp
    end

    return bodyPosition, bodyGyro
end

function MovementController.destroyHoldInstances()
    if not hrp then
        return
    end

    local bodyPosition = hrp:FindFirstChild(HOLD_POSITION_NAME)
    local bodyGyro = hrp:FindFirstChild(HOLD_GYRO_NAME)

    if bodyPosition then
        bodyPosition:Destroy()
    end

    if bodyGyro then
        bodyGyro:Destroy()
    end
end

function MovementController.updateHoldTarget(targetCF)
    if not targetCF or not refreshCharacterRefs() or not hrp then
        return
    end

    State.holdTargetCF = targetCF

    if not State.holdEnabled then
        return
    end

    local bodyPosition, bodyGyro = MovementController.ensureHoldInstances()
    if not bodyPosition or not bodyGyro then
        return
    end

    bodyPosition.Position = targetCF.Position
    bodyGyro.CFrame = targetCF

    MovementController.zeroVelocity()

    if hum then
        hum.AutoRotate = false
        hum.Sit = false
    end
end

function MovementController.setHoldState(enabled, targetCF)
    if enabled then
        State.holdEnabled = true
        MovementController.updateHoldTarget(targetCF or (hrp and hrp.CFrame or nil))

        if not State.connections.Hold then
            State.connections.Hold = RunService.Heartbeat:Connect(function()
                if not State.holdEnabled then
                    return
                end

                if not refreshCharacterRefs() or not hrp then
                    return
                end

                local desiredCF = State.holdTargetCF or hrp.CFrame
                local bodyPosition, bodyGyro = MovementController.ensureHoldInstances()

                if not bodyPosition or not bodyGyro then
                    return
                end

                bodyPosition.Position = desiredCF.Position
                bodyGyro.CFrame = desiredCF

                if hrp.AssemblyLinearVelocity.Magnitude > 0.01 or hrp.AssemblyAngularVelocity.Magnitude > 0.01 then
                    MovementController.zeroVelocity()
                end

                if hum then
                    hum.AutoRotate = false
                    hum.Sit = false
                end
            end)
        end

        return
    end

    State.holdEnabled = false
    State.holdTargetCF = nil

    if State.connections.Hold then
        State.connections.Hold:Disconnect()
        State.connections.Hold = nil
    end

    if hum then
        hum.AutoRotate = true
    end

    MovementController.destroyHoldInstances()
end

function MovementController.shouldUseHold()
    return ((FarmController.isEnabled() and Config.StaticMode and State.activeTargetLockCF ~= nil) or (State.fpsBoostEnabled and Config.FreezeOnFPSBoost))
end

function MovementController.syncHoldState()
    if MovementController.shouldUseHold() then
        local desiredCF = State.activeTargetLockCF
        if not desiredCF and hrp then
            desiredCF = hrp.CFrame
        end

        MovementController.setHoldState(true, desiredCF)
        return
    end

    MovementController.setHoldState(false)
end

function MovementController.getTargetCFrameForNPC(npc)
    if not NPCController.isValid(npc) then
        return nil
    end

    local root = NPCController.getRoot(npc)
    local sourceCF
    local focusPosition

    if root then
        sourceCF = root.CFrame
        focusPosition = root.Position
    else
        local ok, pivot = pcall(function()
            return npc:GetPivot()
        end)

        if not ok or not pivot then
            return nil
        end

        sourceCF = pivot
        focusPosition = pivot.Position
    end

    local targetPosition = sourceCF.Position - (sourceCF.LookVector * Config.DistanceBehind) + Vector3.new(0, Config.HeightOffset, 0)
    return CFrame.new(targetPosition, focusPosition)
end

function MovementController.getTeleportCooldown()
    return math.max(INTERNAL.TELEPORT_COOLDOWN_MIN, math.min(Config.TPDelay, 0.18))
end

function MovementController.shouldReposition(targetCF)
    if not targetCF or not refreshCharacterRefs() or not hrp then
        return false
    end

    local distance = (hrp.Position - targetCF.Position).Magnitude

    if distance <= INTERNAL.MIN_POSITION_EPSILON then
        return false
    end

    if distance >= INTERNAL.REPOSITION_THRESHOLD then
        return true
    end

    return not State.holdEnabled and distance >= (INTERNAL.MIN_POSITION_EPSILON * 2)
end

function MovementController.safePivotTo(targetCF, force)
    if not targetCF or not refreshCharacterRefs() or not char or not hrp then
        return false
    end

    if hum then
        hum.Sit = false
        hum.PlatformStand = false
        pcall(function()
            hum:ChangeState(Enum.HumanoidStateType.RunningNoPhysics)
        end)
    end

    if hrp.Anchored then
        pcall(function()
            hrp.Anchored = false
        end)
    end

    local distance = (hrp.Position - targetCF.Position).Magnitude

    if distance <= INTERNAL.MIN_POSITION_EPSILON and not force then
        if State.holdEnabled then
            MovementController.updateHoldTarget(targetCF)
        end
        return false
    end

    local now = os.clock()
    if not force and (now - State.lastTeleportAt) < MovementController.getTeleportCooldown() and distance < INTERNAL.HARD_REPOSITION_THRESHOLD then
        if State.holdEnabled then
            MovementController.updateHoldTarget(targetCF)
        end
        return false
    end

    if not State.connections.NoClip or not State.connections.NoClipDesc then
        CharacterController.enableNoClip()
    end

    if Config.BypassTP and distance > INTERNAL.LONG_TELEPORT_THRESHOLD then
        local currentPosition = hrp.Position
        local finalPosition = targetCF.Position
        local steps = math.clamp(math.ceil(distance / INTERNAL.TELEPORT_SEGMENT_MAX), 1, 10)

        for index = 1, (steps - 1) do
            if not State.alive or not char or not char.Parent then
                break
            end

            local alpha = index / steps
            local stepPosition = currentPosition:Lerp(finalPosition, alpha)
            local stepCF = CFrame.new(stepPosition, finalPosition)

            pcall(function()
                hrp.CFrame = stepCF
            end)
            pcall(function()
                char:PivotTo(stepCF)
            end)
            MovementController.zeroVelocity()

            if State.holdEnabled then
                MovementController.updateHoldTarget(stepCF)
            end

            task.wait(INTERNAL.TELEPORT_SEGMENT_WAIT)
        end
    end

    pcall(function()
        hrp.CFrame = targetCF
    end)
    pcall(function()
        char:PivotTo(targetCF)
    end)
    MovementController.zeroVelocity()

    State.lastTeleportAt = os.clock()

    if State.holdEnabled then
        MovementController.updateHoldTarget(targetCF)
    end

    return true
end

function MovementController.moveToward(targetCF)
    if not targetCF then
        return false
    end

    if MovementController.shouldReposition(targetCF) then
        return MovementController.safePivotTo(targetCF, false)
    end

    if State.holdEnabled then
        MovementController.updateHoldTarget(targetCF)
    end

    return false
end

local function rememberVisualProperty(inst, propertyName)
    local bucket = State.visual.visuals[inst]
    if not bucket then
        bucket = {}
        State.visual.visuals[inst] = bucket
    end

    if bucket[propertyName] == nil then
        local ok, value = pcall(function()
            return inst[propertyName]
        end)

        if ok then
            bucket[propertyName] = value
        end
    end
end

local function rememberLightingProperty(key, value)
    if State.visual.lightingProps[key] == nil then
        State.visual.lightingProps[key] = value
    end
end

function VisualController.disconnectConnections()
    for _, connection in ipairs(State.visual.connections) do
        if connection then
            connection:Disconnect()
        end
    end

    table.clear(State.visual.connections)
end

function VisualController.getHiddenStorage()
    if not State.visual.hiddenStorage then
        local folder = Instance.new("Folder")
        folder.Name = "Lapo_FPSHiddenStorage"
        State.visual.hiddenStorage = folder
    end

    return State.visual.hiddenStorage
end

function VisualController.getWorkspaceRoot(inst)
    local current = inst

    while current and current.Parent and current.Parent ~= Workspace do
        current = current.Parent
    end

    if current and current.Parent == Workspace then
        return current
    end

    return nil
end

function VisualController.isProtectedInstance(inst)
    if not inst then
        return true
    end

    if inst == Workspace.CurrentCamera then
        return true
    end

    if inst:IsA("Terrain") then
        return true
    end

    if char and inst:IsDescendantOf(char) then
        return true
    end

    if inst:IsA("Model") and Players:GetPlayerFromCharacter(inst) then
        return true
    end

    local npcFolder = getNPCFolder()
    if npcFolder and (inst == npcFolder or inst:IsDescendantOf(npcFolder)) then
        return true
    end

    return false
end

function VisualController.hideWorkspaceRoot(root)
    if not State.fpsBoostEnabled or not root or not root.Parent then
        return false
    end

    if VisualController.isProtectedInstance(root) or State.visual.hiddenRoots[root] then
        return false
    end

    local hiddenStorage = VisualController.getHiddenStorage()
    local originalParent = root.Parent
    local ok = pcall(function()
        root.Parent = hiddenStorage
    end)

    if ok and root.Parent == hiddenStorage then
        State.visual.hiddenRoots[root] = originalParent
        return true
    end

    return false
end

function VisualController.stripWorkspaceVisual(inst)
    if not State.fpsBoostEnabled or not inst then
        return
    end

    local workspaceRoot = inst.Parent == Workspace and inst or VisualController.getWorkspaceRoot(inst)
    if workspaceRoot and VisualController.hideWorkspaceRoot(workspaceRoot) then
        return
    end

    if inst:IsA("Terrain") then
        rememberLightingProperty("TerrainDecoration", inst.Decoration)
        rememberLightingProperty("TerrainWaterWaveSize", inst.WaterWaveSize)
        rememberLightingProperty("TerrainWaterWaveSpeed", inst.WaterWaveSpeed)
        rememberLightingProperty("TerrainWaterTransparency", inst.WaterTransparency)

        inst.Decoration = false
        inst.WaterWaveSize = 0
        inst.WaterWaveSpeed = 0
        inst.WaterTransparency = 1
    end
end

function VisualController.stripLightingVisual(inst)
    if not State.fpsBoostEnabled or not inst then
        return
    end

    if inst:IsA("PostEffect") then
        rememberVisualProperty(inst, "Enabled")
        inst.Enabled = false
    elseif inst:IsA("Atmosphere") then
        rememberVisualProperty(inst, "Density")
        rememberVisualProperty(inst, "Haze")
        rememberVisualProperty(inst, "Glare")
        inst.Density = 0
        inst.Haze = 0
        inst.Glare = 0
    elseif inst:IsA("Clouds") then
        rememberVisualProperty(inst, "Enabled")
        inst.Enabled = false
    end
end

function VisualController.restore()
    VisualController.disconnectConnections()

    for inst, originalParent in pairs(State.visual.hiddenRoots) do
        if inst and originalParent then
            pcall(function()
                inst.Parent = originalParent
            end)
        end
    end

    table.clear(State.visual.hiddenRoots)

    for inst, properties in pairs(State.visual.visuals) do
        if inst then
            for propertyName, originalValue in pairs(properties) do
                pcall(function()
                    inst[propertyName] = originalValue
                end)
            end
        end
    end

    table.clear(State.visual.visuals)

    local terrain = Workspace:FindFirstChildOfClass("Terrain")
    for key, value in pairs(State.visual.lightingProps) do
        pcall(function()
            if key == "GlobalShadows" then
                Lighting.GlobalShadows = value
            elseif key == "TerrainDecoration" and terrain then
                terrain.Decoration = value
            elseif key == "TerrainWaterWaveSize" and terrain then
                terrain.WaterWaveSize = value
            elseif key == "TerrainWaterWaveSpeed" and terrain then
                terrain.WaterWaveSpeed = value
            elseif key == "TerrainWaterTransparency" and terrain then
                terrain.WaterTransparency = value
            end
        end)
    end

    table.clear(State.visual.lightingProps)

    if State.visual.hiddenStorage then
        State.visual.hiddenStorage:Destroy()
        State.visual.hiddenStorage = nil
    end
end

function VisualController.apply(state)
    State.fpsBoostEnabled = state

    if state then
        VisualController.restore()

        rememberLightingProperty("GlobalShadows", Lighting.GlobalShadows)
        Lighting.GlobalShadows = false

        for _, inst in ipairs(Workspace:GetChildren()) do
            VisualController.stripWorkspaceVisual(inst)
        end

        local terrain = Workspace:FindFirstChildOfClass("Terrain")
        if terrain then
            VisualController.stripWorkspaceVisual(terrain)
        end

        for _, inst in ipairs(Lighting:GetDescendants()) do
            VisualController.stripLightingVisual(inst)
        end

        table.insert(State.visual.connections, Workspace.ChildAdded:Connect(function(inst)
            if not State.fpsBoostEnabled then
                return
            end

            task.defer(function()
                if State.fpsBoostEnabled then
                    VisualController.stripWorkspaceVisual(inst)
                end
            end)
        end))

        table.insert(State.visual.connections, Lighting.DescendantAdded:Connect(function(inst)
            if not State.fpsBoostEnabled then
                return
            end

            task.defer(function()
                if State.fpsBoostEnabled then
                    VisualController.stripLightingVisual(inst)
                end
            end)
        end))
    else
        VisualController.restore()
    end

    MovementController.syncHoldState()
end

function FarmController.isEnabled()
    return State.farmMode ~= "none"
end

function FarmController.clearTarget()
    State.activeTarget = nil
    State.activeTargetBaseName = nil
    State.activeTargetKind = "None"
    State.activeTargetLockCF = nil
    State.lastLockCFRefreshAt = 0
    State.LastTarget = "None"
end

function FarmController.setMode(mode)
    mode = tostring(mode or "none")

    if not MODE_LABELS[mode] then
        mode = "none"
    end

    State.farmMode = mode
    State.LastMode = MODE_LABELS[mode]

    Config.FarmAllSelected = mode == "all"
    Config.FarmingEnemies = mode == "mobs"
    Config.FarmingBosses = mode == "bosses"
    Config.FarmTimedBosses = mode == "timed"

    if mode == "none" then
        FarmController.clearTarget()
    else
        State.lastTargetRefreshAt = 0
    end

    MovementController.syncHoldState()
end

function FarmController.invalidateTargetIfNeeded()
    if State.activeTarget and not FarmController.isCandidateAllowed(State.activeTarget) then
        FarmController.clearTarget()
    end
end

function FarmController.isCandidateAllowed(npc)
    if not FarmController.isEnabled() then
        return false
    end

    if not NPCController.isValid(npc) then
        return false
    end

    local baseName = NPCController.getBaseName(npc.Name)
    local isBoss = NPCController.isBossName(npc.Name)
    local isTimedBoss = TIMED_BOSS_LOOKUP[npc.Name] == true
    local selectedMobsCount = countEnabled(Config.SelectedEnemies)
    local selectedBossCount = countEnabled(Config.SelectedBosses)

    if State.farmMode == "timed" then
        return isTimedBoss
    end

    if State.farmMode == "mobs" then
        return not isBoss and (selectedMobsCount == 0 or Config.SelectedEnemies[baseName] == true)
    end

    if State.farmMode == "bosses" then
        return isBoss and (selectedBossCount == 0 or Config.SelectedBosses[baseName] == true)
    end

    if State.farmMode == "all" then
        if isBoss then
            return selectedBossCount == 0 or Config.SelectedBosses[baseName] == true
        end

        return selectedMobsCount == 0 or Config.SelectedEnemies[baseName] == true
    end

    return false
end

function FarmController.shouldKeepTarget(npc)
    return npc ~= nil and FarmController.isCandidateAllowed(npc)
end

function FarmController.getTargetKind(npc)
    if not npc then
        return "None"
    end

    if TIMED_BOSS_LOOKUP[npc.Name] then
        return "Timed Boss"
    end

    if NPCController.isBossName(npc.Name) then
        return "Boss"
    end

    return "Mob"
end

function FarmController.pickClosest(candidates)
    return FarmController.pickClosestExcluding(candidates, nil)
end

function FarmController.pickClosestExcluding(candidates, exclude)
    local bestNPC = nil
    local bestDistance = math.huge

    for _, npc in ipairs(candidates) do
        if npc ~= exclude then
        local distance = NPCController.getDistanceFromCharacter(npc)

        if distance < bestDistance then
            bestDistance = distance
            bestNPC = npc
        end
        end
    end

    return bestNPC
end

function FarmController.acquireTarget(forceRefresh, exclude)
    NPCController.refreshCache(forceRefresh)

    local timedCandidates = {}
    local regularCandidates = {}

    if State.farmMode == "timed" then
        for _, npc in ipairs(NPCController.getTimedBosses(false)) do
            if FarmController.isCandidateAllowed(npc) then
                table.insert(timedCandidates, npc)
            end
        end
    else
        for _, npc in ipairs(NPCController.getValidNPCs(false)) do
            if FarmController.isCandidateAllowed(npc) then
                if TIMED_BOSS_LOOKUP[npc.Name] and State.farmMode ~= "mobs" then
                    table.insert(timedCandidates, npc)
                else
                    table.insert(regularCandidates, npc)
                end
            end
        end
    end

    local nextTarget = nil

    if #timedCandidates > 0 then
        nextTarget = FarmController.pickClosestExcluding(timedCandidates, exclude)
    elseif #regularCandidates > 0 then
        nextTarget = FarmController.pickClosestExcluding(regularCandidates, exclude)
    else
        for _, npc in ipairs(NPCController.getListableNPCs()) do
            if npc ~= exclude and FarmController.isCandidateAllowed(npc) and MovementController.getTargetCFrameForNPC(npc) then
                nextTarget = npc
                break
            end
        end
    end

    if not nextTarget and exclude ~= nil then
        return FarmController.acquireTarget(forceRefresh, nil)
    end

    if nextTarget then
        State.activeTarget = nextTarget
        State.activeTargetBaseName = NPCController.getBaseName(nextTarget.Name)
        State.activeTargetKind = FarmController.getTargetKind(nextTarget)
        State.activeTargetLockCF = nil
        State.lastLockCFRefreshAt = 0
        State.LastTarget = nextTarget.Name
    else
        FarmController.clearTarget()
    end

    State.lastTargetRefreshAt = os.clock()
    return nextTarget
end

function FarmController.refreshTargetLock(force)
    if not FarmController.shouldKeepTarget(State.activeTarget) then
        return nil
    end

    local now = os.clock()

    if force or not State.activeTargetLockCF or (now - State.lastLockCFRefreshAt) >= INTERNAL.TARGET_CF_REFRESH then
        State.activeTargetLockCF = MovementController.getTargetCFrameForNPC(State.activeTarget)
        State.lastLockCFRefreshAt = now
    end

    return State.activeTargetLockCF
end

function FarmController.getStepDelay(activeTargetExists)
    if activeTargetExists then
        return math.max(INTERNAL.FARM_TICK_MIN, Config.TPDelay)
    end

    return INTERNAL.TARGET_LOST_TICK
end

function FarmController.step()
    local acquiredNewTarget = false

    if not FarmController.isEnabled() then
        FarmController.clearTarget()
        MovementController.syncHoldState()
        return INTERNAL.IDLE_TICK
    end

    if not refreshCharacterRefs() or not hum or not hrp or hum.Health <= 0 then
        MovementController.syncHoldState()
        return INTERNAL.IDLE_TICK
    end

    if not State.connections.NoClip or not State.connections.NoClipDesc then
        CharacterController.enableNoClip()
    end

    if State.activeTarget and not FarmController.shouldKeepTarget(State.activeTarget) then
        local died = not NPCController.isAlive(State.activeTarget)
        FarmController.clearTarget()

        if died then
            MovementController.syncHoldState()
            return Config.Delay
        end
    end

    if not State.activeTarget then
        FarmController.acquireTarget(true, State.lastCycleSkip)
        acquiredNewTarget = State.activeTarget ~= nil
    elseif (os.clock() - State.lastTargetRefreshAt) >= INTERNAL.NPC_CACHE_TTL then
        NPCController.refreshCache(true)
        State.lastTargetRefreshAt = os.clock()

        if not FarmController.shouldKeepTarget(State.activeTarget) then
            FarmController.clearTarget()
            FarmController.acquireTarget(false, State.lastCycleSkip)
            acquiredNewTarget = State.activeTarget ~= nil
        end
    end

    if State.activeTarget and Config.CycleTargets then
        local now = os.clock()
        local interval = math.clamp(tonumber(Config.CycleInterval) or 2.5, 0.35, 30)
        if (now - (State.lastCycleAt or 0)) >= interval then
            State.lastCycleAt = now
            State.lastCycleSkip = State.activeTarget
            FarmController.clearTarget()
            FarmController.acquireTarget(true, State.lastCycleSkip)
            acquiredNewTarget = State.activeTarget ~= nil
        end
    end

    if not State.activeTarget then
        MovementController.syncHoldState()
        return FarmController.getStepDelay(false)
    end

    if Config.AutoEquip then
        EquipController.equipSelected(false)
    end

    local targetCF = FarmController.refreshTargetLock(false)
    if not targetCF then
        FarmController.clearTarget()
        MovementController.setHoldState(false)
        MovementController.syncHoldState()
        return FarmController.getStepDelay(false)
    end

    if acquiredNewTarget then
        MovementController.setHoldState(false)
        targetCF = FarmController.refreshTargetLock(true) or targetCF
        MovementController.safePivotTo(targetCF, true)
    end

    if MovementController.shouldUseHold() then
        MovementController.setHoldState(true, targetCF)
    elseif State.holdEnabled then
        MovementController.setHoldState(false)
    end

    MovementController.moveToward(targetCF)

    CombatController.tryActivateTool()

    if State.holdEnabled and State.activeTargetLockCF then
        MovementController.updateHoldTarget(State.activeTargetLockCF)
    end

    if not NPCController.isAlive(State.activeTarget) then
        FarmController.clearTarget()
        return Config.Delay
    end

    return FarmController.getStepDelay(true)
end

