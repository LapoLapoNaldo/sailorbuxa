                end

                teleportToTarget(target)
                attack()

                if Config.AirHold and State.Root then
                    holdInAir(State.Root.CFrame)
                end
            else
                State.Target = nil
                State.TargetName = "None"

                if farming then
                    tryInfiniteRangeTeleport()
                end

                if Config.AirHold and State.Root then
                    holdInAir(State.Root.CFrame)
                else
                    disableAirHold()
                end
            end

            task.wait(Config.Delay)
        end
    end
end)