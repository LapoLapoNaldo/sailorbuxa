local requestFn = syn and syn.request or http_request or request or (http and http.request)
assert(requestFn, "request function not found")

local function httpGet(url)
    local res = requestFn({
        Url = url,
        Method = "GET"
    })

    local body = res and (res.Body or res.body)
    assert(body, "failed to load: " .. tostring(url))
    return body
end

