local function refreshCharacterRefs(newChar, allowWait)
    char = newChar or LocalPlayer.Character
    hum = nil
    hrp = nil

    if not char then
        return false
    end

    hum = char:FindFirstChildOfClass("Humanoid")
    hrp = char:FindFirstChild("HumanoidRootPart")

    if allowWait then
        hum = hum or char:WaitForChild("Humanoid", 10)
        hrp = hrp or char:WaitForChild("HumanoidRootPart", 10)
    end

    return hum ~= nil and hrp ~= nil
end

local function countEnabled(selectionMap)
    local total = 0

    for _, enabled in pairs(selectionMap) do
        if enabled then
            total = total + 1
        end
    end

    return total
end

local function getNPCFolder()
    local directNames = { "NPCs", "Enemies", "Mobs" }

    for _, folderName in ipairs(directNames) do
        local folder = Workspace:FindFirstChild(folderName)
        if folder then
            return folder
        end
    end

    for _, inst in ipairs(Workspace:GetDescendants()) do
        if (inst:IsA("Folder") or inst:IsA("Model")) and table.find(directNames, inst.Name) then
            return inst
        end
    end

    return nil
end

local function notify(title, content, icon, duration)
    WindUI:Notify({
